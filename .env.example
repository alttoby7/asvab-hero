NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_AMAZON_TAG=asvabhero-20

# Paywall "why-tracking" — client kill-switch (build-time). Set to "true" to
# enable first-party event emission + the cancel-return survey. Unset/anything
# else = disabled (GA4 still fires). See why-tracking-spec §10.
NEXT_PUBLIC_WHY_TRACKING_ENABLED=

# Adaptive AFQT selector (WS6) — client kill-switch (build-time). "true" routes
# the `afqt_adaptive` variant through the adaptive next-item engine. Requires
# BOTH this flag AND the `afqt_adaptive` test_variants row being active=true.
# Keep UNSET until the AFQT content-depth gate (>=900 audited items) is met.
NEXT_PUBLIC_ADAPTIVE_ENABLED=

# --- Cloudflare Pages Functions env vars (set in CF dashboard, NOT this file) ---
# Required by functions/api/events.ts + functions/api/feedback.ts:
#   SUPABASE_URL                 (service-role context; project URL)
#   SUPABASE_SERVICE_ROLE_KEY    (SECRET; service role — bypasses RLS)
#   SUPABASE_ANON_KEY            (to validate optional Bearer JWT)
#   RATE_LIMIT_KV                (reuse existing KV binding from signup.ts)
#   WHY_TRACKING_ENABLED         ("true" to enable; unset = 204 short-circuit)
#   FEEDBACK_FREE_TEXT_ENABLED   (default off; do not enable for v1)
#   ASVABHERO_SENTRY_DSN_EDGE / ASVABHERO_ENV / ASVABHERO_RELEASE (as signup.ts)
