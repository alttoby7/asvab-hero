NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_AMAZON_TAG=asvabhero-20

# Printed-book /review page (build-time). UNSET = show "search Amazon" fallback.
# Set to the book's ASIN once it's published, then redeploy → /review redirects
# to Amazon's write-a-review deep link for "ASVAB Math, Explained".
NEXT_PUBLIC_REVIEW_BOOK_ASIN=

# Paywall "why-tracking" — client kill-switch (build-time). Set to "true" to
# enable first-party event emission + the cancel-return survey. Unset/anything
# else = disabled (GA4 still fires). See why-tracking-spec §10.
NEXT_PUBLIC_WHY_TRACKING_ENABLED=

# Adaptive AFQT selector (WS6) — client kill-switch (build-time). "true" routes
# the `afqt_adaptive` variant through the adaptive next-item engine. Requires
# BOTH this flag AND the `afqt_adaptive` test_variants row being active=true.
# Keep UNSET until the AFQT content-depth gate (>=900 audited items) is met.
NEXT_PUBLIC_ADAPTIVE_ENABLED=

# Save-gate — "gate the saved result" free-account conversion lever (build-time).
# Let visitors compute their score free, but require a FREE account to keep and
# act on it (full qualifying-jobs list, saved result, study plan). NOT the paid
# paywall. Unset/anything but "true" = OFF.
#
# CALCULATOR gate (NEW): OFF by default. Turning it on shows anonymous visitors a
# count + top-3 teaser of qualifying jobs instead of the full list, with a
# free-account CTA. This is the surface to A/B first (highest-traffic page).
#   NEXT_PUBLIC_SAVE_GATE_ENABLED             master switch — turns BOTH on
#   NEXT_PUBLIC_SAVE_GATE_CALCULATOR_ENABLED  turn the calculator gate on
#
# DIAGNOSTIC gate: the practice-test results soft-gate for anonymous users is
# ALREADY LIVE and behaves the same whether or not this flag is set (the score is
# shown free; the weak-area breakdown + plan require a free account). The flag is
# reserved so the diagnostic surface can be toggled/branched in a later A/B; it
# does not currently change diagnostic behavior on its own.
#   NEXT_PUBLIC_SAVE_GATE_DIAGNOSTIC_ENABLED  reserved for the diagnostic A/B
#
# NOTE: the save-gate funnel events (result_revealed, save_gate_viewed,
# save_gate_signup_click, account_created_from_gate) ride the same first-party
# pipeline as the paywall events, so they only emit when why-tracking is enabled
# (NEXT_PUBLIC_WHY_TRACKING_ENABLED + WHY_TRACKING_ENABLED). GA4 fires regardless.
NEXT_PUBLIC_SAVE_GATE_ENABLED=
NEXT_PUBLIC_SAVE_GATE_CALCULATOR_ENABLED=
NEXT_PUBLIC_SAVE_GATE_DIAGNOSTIC_ENABLED=

# --- Cloudflare Pages Functions env vars (set in CF dashboard, NOT this file) ---
# Required by functions/api/events.ts + functions/api/feedback.ts:
#   SUPABASE_URL                 (service-role context; project URL)
#   SUPABASE_SERVICE_ROLE_KEY    (SECRET; service role — bypasses RLS)
#   SUPABASE_ANON_KEY            (to validate optional Bearer JWT)
#   RATE_LIMIT_KV                (reuse existing KV binding from signup.ts)
#   WHY_TRACKING_ENABLED         ("true" to enable; unset = 204 short-circuit)
#   FEEDBACK_FREE_TEXT_ENABLED   (default off; do not enable for v1)
#   ASVABHERO_SENTRY_DSN_EDGE / ASVABHERO_ENV / ASVABHERO_RELEASE (as signup.ts)
#   LISTMONK_TEMPLATE_BOOK       (optional; welcome template for the book-QR `book`
#                                 tag. Unset = falls back to LISTMONK_WELCOME_TEMPLATE_ID.)
